{
  "manifest_version": 3,
  "name": "reader",
  "version": "0.1.0",
  "description": "Automatically bolds the leading letters of readable words on webpages and PDFs.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  },
  "action": {
    "default_title": "reader",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/browser-api.js",
        "shared/config.js",
        "shared/pdf-routing.js",
        "vendor/pdf-lib/pdf-lib.js",
        "shared/pdf-bionicize.js",
        "shared/reader-engine.js",
        "content/content.js"
      ],
      "css": [
        "content/reader.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdf/*",
        "shared/*",
        "vendor/pdf-lib/*",
        "vendor/pdfjs/*",
        "vendor/pdfjs/cmaps/*",
        "vendor/pdfjs/standard_fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
